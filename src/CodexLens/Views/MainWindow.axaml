

<suki:SukiWindow xmlns="https://github.com/avaloniaui"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:suki="clr-namespace:SukiUI.Controls;assembly=SukiUI"
                 xmlns:vm="clr-namespace:CodexLens.ViewModels"
                 xmlns:models="clr-namespace:CodexLens.Models"
                 x:Class="CodexLens.Views.MainWindow"
                 x:DataType="vm:MainWindowViewModel"
                 mc:Ignorable="d"
                 Width="1380"
                 Height="860"
                 MinWidth="1080"
                 MinHeight="640"
                 Title="Codex Lens"
                 Background="#FBF7EF"
                 KeyDown="Window_KeyDown"
                 BackgroundStyle="Flat">
  <suki:SukiWindow.Styles>
    <Style Selector="Button.roundIconButton">
      <Setter Property="Width" Value="34" />
      <Setter Property="Height" Value="34" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="ListBox.sessionList ListBoxItem:selected /template/ Path">
      <Setter Property="Fill" Value="#E97924" />
    </Style>
    <Style Selector="ListBox.sessionList ListBoxItem:selected /template/ PathIcon">
      <Setter Property="Foreground" Value="#E97924" />
    </Style>
    <Style Selector="ListBox.sessionList ListBoxItem">
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0" />
      <Setter Property="Template">
        <ControlTemplate>
          <Border Background="Transparent"
                  BorderThickness="0"
                  Padding="0"
                  Margin="0">
            <ContentPresenter Name="PART_ContentPresenter"
                              Content="{TemplateBinding Content}"
                              ContentTemplate="{TemplateBinding ContentTemplate}"
                              HorizontalContentAlignment="Stretch"
                              VerticalContentAlignment="Stretch"
                              Background="Transparent"
                              BorderThickness="0"
                              Padding="{TemplateBinding Padding}" />
          </Border>
        </ControlTemplate>
      </Setter>
    </Style>
    <Style Selector="ListBox.sessionList Border.sessionCard">
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="BorderBrush" Value="#E7DCCB" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="ListBox.sessionList ListBoxItem:selected Border.sessionCard">
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="BorderBrush" Value="#E97924" />
      <Setter Property="BorderThickness" Value="2" />
    </Style>
    <Style Selector="ScrollViewer.accentScrollArea ScrollBar /template/ Thumb">
      <Setter Property="Background" Value="#E97924" />
    </Style>
    <Style Selector="ScrollViewer.accentScrollArea ScrollBar:pointerover /template/ Thumb">
      <Setter Property="Background" Value="#D76618" />
    </Style>
    <Style Selector="ProgressBar.accentProgress">
      <Setter Property="Foreground" Value="#E97924" />
      <Setter Property="Background" Value="#F3DFCF" />
    </Style>
    <Style Selector="ProgressBar.accentProgress /template/ Rectangle">
      <Setter Property="Fill" Value="#E97924" />
    </Style>
    <Style Selector="Border.transcriptPane">
      <Setter Property="BorderBrush" Value="#E7DCCB" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="Border.transcriptPane.active">
      <Setter Property="BorderBrush" Value="#E97924" />
      <Setter Property="BorderThickness" Value="2" />
    </Style>
  </suki:SukiWindow.Styles>
  
  <Grid RowDefinitions="Auto,*,Auto"
        ColumnDefinitions="340,*"
        Margin="14"
        ColumnSpacing="12"
        RowSpacing="12"
        Background="#FBF7EF">

    <Border Grid.Row="0"
            Grid.ColumnSpan="2"
            CornerRadius="18"
            Padding="12"
            Background="#FFFDF8"
            BorderBrush="#E7DCCB"
            BorderThickness="1">
      <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" ColumnSpacing="10" VerticalAlignment="Center">
        <TextBlock Text="Sessions root"
                   FontWeight="SemiBold"
                   VerticalAlignment="Center"
                   Foreground="#3E3A36"/>

        <TextBox Grid.Column="1"
                 Text="{Binding RootPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 PlaceholderText="C:\Users\you\.codex\sessions 或 WSL UNC 路径"
                 FontFamily="Consolas"/>

        <Button Grid.Column="2" Classes="toolbarButton" Content="Default" Command="{Binding OpenDefaultRootCommand}"/>
        <Button Grid.Column="3" Classes="toolbarButton" Content="Refresh" Command="{Binding RefreshCommand}"/>
        <CheckBox Grid.Column="4"
                  Classes="preferenceCheckBox"
                  Content="Pin selected"
                  IsThreeState="False"
                  IsChecked="{Binding PinSelectedSession, Mode=TwoWay}"
                  VerticalAlignment="Center"/>
      </Grid>
    </Border>

    <Border Grid.Row="1"
            Grid.Column="0"
            CornerRadius="18"
            Padding="10"
            Background="#FFFDF8"
            BorderBrush="#E7DCCB"
            BorderThickness="1">
      <Grid RowDefinitions="Auto,Auto,*" RowSpacing="10">
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel>
            <TextBlock Text="Codex sessions"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="#3A3732"/>
            <TextBlock Text="{Binding SessionCountText}"
                       Foreground="#746A5F"/>
          </StackPanel>

          <Border Grid.Column="1"
                  CornerRadius="8"
                  Padding="6,1"
                  VerticalAlignment="Top"
                  Background="#FFFFFF"
                  BorderBrush="#E7DCCB"
                  BorderThickness="1">
            <TextBlock Text="只读"
                       FontSize="12"
                       Foreground="#6C7A6F"/>
          </Border>
        </Grid>

        <TextBox Grid.Row="1"
                 Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 PlaceholderText="搜索当前 session：回复 / 命令 / diff / raw"/>

        <ListBox Grid.Row="2"
                 Classes="sessionList"
                 ItemsSource="{Binding Sessions}"
                 SelectedItem="{Binding SelectedSession, Mode=TwoWay}">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="models:SessionInfo">
              <Border Classes="sessionCard"
                      CornerRadius="10"
                      Padding="8"
                      Margin="0,2">
                <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="4">
                  <TextBlock Text="{Binding DisplayTitle}"
                             FontWeight="SemiBold"
                             TextWrapping="Wrap"
                             MaxLines="2"
                             Foreground="#3D3445"/>

                  <Border Grid.Column="1"
                          CornerRadius="8"
                          Padding="6,1"
                          VerticalAlignment="Top"
                          Background="#F8F8F8"
                          BorderBrush="#E7DCCB"
                          BorderThickness="1">
                    <TextBlock Text="{Binding StatusText}"
                               FontSize="11"
                               Foreground="#7A6F63"/>
                  </Border>

                  <TextBlock Grid.Row="1"
                             Grid.ColumnSpan="2"
                             Text="{Binding DisplaySubtitle}"
                             Foreground="#746A5F"
                             FontSize="12"/>

                  <TextBlock Grid.Row="2"
                             Grid.ColumnSpan="2"
                             Text="{Binding FilePath}"
                             Foreground="#9A9187"
                             FontSize="11"
                             TextTrimming="CharacterEllipsis"/>
                </Grid>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Grid>
    </Border>

    <Grid Grid.Row="1" Grid.Column="1" RowDefinitions="Auto,*" RowSpacing="10">
      <Border CornerRadius="18"
              Padding="10"
              Background="#FFFDF8"
              BorderBrush="#E7DCCB"
              BorderThickness="1">
        <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto" ColumnSpacing="10">
          <StackPanel>
            <TextBlock Text="{Binding SelectedSessionPath}"
                       FontFamily="Consolas"
                       TextTrimming="CharacterEllipsis"
                       Foreground="#3A3732"/>
            <TextBlock Text="{Binding EventCountText}"
                       Foreground="#746A5F"
                       FontSize="12"/>
          </StackPanel>

          <Button Grid.Column="2"
                  Classes="toolbarButton"
                  Content="Settings"
                  VerticalAlignment="Center"
                  Click="Settings_Click"/>

          <ComboBox Grid.Column="3"
                    ItemsSource="{Binding FilterOptions}"
                    SelectedItem="{Binding SelectedFilter}"
                    MinWidth="150"/>

          <Button Grid.Column="4"
                  Classes="toolbarButton"
                  Content="Clear search"
                  VerticalAlignment="Center"
                  Command="{Binding ClearSearchCommand}"/>

          <ToggleButton Grid.Column="1"
                        Classes="toolbarButton"
                        Content="Raw"
                        VerticalAlignment="Center"
                        IsChecked="{Binding ShowRawEvents}"/>
        </Grid>
      </Border>

      <Grid Grid.Row="1"
            ColumnDefinitions="*,8,*"
            RowDefinitions="*,Auto"
            ColumnSpacing="0"
            RowSpacing="10">

        <Border Grid.Column="0"
                Classes="transcriptPane"
                Classes.active="{Binding IsConversationPaneActive}"
                CornerRadius="18"
                Padding="10"
                Background="#FFFDF8">
          <Grid RowDefinitions="Auto,*" RowSpacing="8">
            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
              <TextBlock Text="Conversation"
                         FontSize="18"
                         FontWeight="Bold"
                         Foreground="#3A3732"
                         VerticalAlignment="Center"/>

              <Button Grid.Column="1"
                      Classes="roundIconButton"
                      Click="ConversationUp_Click"
                      ToolTip.Tip="上一条消息">
                <Border Width="30"
                        Height="30"
                        CornerRadius="15"
                        Background="#FFFFFF"
                        BorderBrush="#E7DCCB"
                        BorderThickness="1">
                  <Path Width="12"
                        Height="12"
                        Stretch="Uniform"
                        Fill="#6F655C"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Data="{StaticResource IconChevronUp}" />
                </Border>
              </Button>

              <Button Grid.Column="2"
                      Classes="roundIconButton"
                      Click="ConversationDown_Click"
                      ToolTip.Tip="下一条消息">
                <Border Width="30"
                        Height="30"
                        CornerRadius="15"
                        Background="#FFFFFF"
                        BorderBrush="#E7DCCB"
                        BorderThickness="1">
                  <Path Width="12"
                        Height="12"
                        Stretch="Uniform"
                        Fill="#6F655C"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Data="{StaticResource IconChevronDown}" />
                </Border>
              </Button>
            </Grid>

            <ScrollViewer x:Name="ConversationScrollViewer"
                          Grid.Row="1"
                          Classes="accentScrollArea">
              <ItemsControl x:Name="ConversationItemsControl"
                            ItemsSource="{Binding ConversationEvents}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="models:DisplayEvent">
                    <Border CornerRadius="16"
                            Padding="12"
                            Margin="0,0,0,10"
                            Background="{Binding CardBackground}"
                            BorderBrush="{Binding CardBorder}"
                            BorderThickness="{Binding CardBorderThickness}">
                      <StackPanel Spacing="7">
                        <Grid ColumnDefinitions="Auto,*">
                          <Border CornerRadius="999"
                                  Padding="8,3"
                                  Background="{Binding RoleBadgeBackground}">
                            <TextBlock Text="{Binding RoleLabel}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{Binding RoleBadgeForeground}"/>
                          </Border>

                          <TextBlock Grid.Column="1"
                                     Text="{Binding TimeText}"
                                     HorizontalAlignment="Right"
                                     FontSize="12"
                                     Foreground="#8A8178"/>
                        </Grid>

                        <TextBlock Text="{Binding Title}"
                                   FontWeight="Bold"
                                   Foreground="#37332F"/>

                        <TextBlock Text="{Binding Text}"
                                   TextWrapping="Wrap"
                                   FontSize="14"
                                   LineHeight="20"
                                   Foreground="#34302C"/>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </Grid>
        </Border>

        <GridSplitter Grid.Column="1"
                      Width="8"
                      Background="#F0E8DC"
                      HorizontalAlignment="Stretch"/>

        <Border Grid.Column="2"
                Classes="transcriptPane"
                Classes.active="{Binding IsExecutionPaneActive}"
                CornerRadius="18"
                Padding="10"
                Background="#FFFDF8">
          <Grid RowDefinitions="Auto,*" RowSpacing="8">
            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
              <TextBlock Text="Execution"
                         FontSize="18"
                         FontWeight="Bold"
                         Foreground="#3A3732"
                         VerticalAlignment="Center"/>

              <Button Grid.Column="1"
                      Width="34"
                      Height="34"
                      Padding="0"
                      Background="Transparent"
                      BorderThickness="0"
                      Click="ExecutionUp_Click"
                      ToolTip.Tip="上一条消息">
                <Border Width="30"
                        Height="30"
                        CornerRadius="15"
                        Background="#FFFFFF"
                        BorderBrush="#E7DCCB"
                        BorderThickness="1">
                  <Path Width="12"
                        Height="12"
                        Stretch="Uniform"
                        Fill="#6F655C"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Data="M 12 6 L 20 17 L 4 17 Z"/>
                </Border>
              </Button>

              <Button Grid.Column="2"
                      Width="34"
                      Height="34"
                      Padding="0"
                      Background="Transparent"
                      BorderThickness="0"
                      Click="ExecutionDown_Click"
                      ToolTip.Tip="下一条消息">
                <Border Width="30"
                        Height="30"
                        CornerRadius="15"
                        Background="#FFFFFF"
                        BorderBrush="#E7DCCB"
                        BorderThickness="1">
                  <Path Width="12"
                        Height="12"
                        Stretch="Uniform"
                        Fill="#6F655C"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Data="M 4 7 L 20 7 L 12 18 Z"/>
                </Border>
              </Button>
            </Grid>

            <ScrollViewer x:Name="ExecutionScrollViewer"
                          Grid.Row="1"
                          Classes="accentScrollArea"
                          HorizontalScrollBarVisibility="Disabled">
              <ItemsControl x:Name="ExecutionItemsControl"
                            ItemsSource="{Binding ExecutionEvents}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="models:DisplayEvent">
                    <Border CornerRadius="16"
                            Padding="12"
                            Margin="0,0,0,10"
                            Background="{Binding CardBackground}"
                            BorderBrush="{Binding CardBorder}"
                            BorderThickness="{Binding CardBorderThickness}">
                      <StackPanel Spacing="7">
                        <Grid ColumnDefinitions="Auto,*">
                          <Border CornerRadius="999"
                                  Padding="8,3"
                                  Background="{Binding RoleBadgeBackground}">
                            <TextBlock Text="{Binding RoleLabel}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{Binding RoleBadgeForeground}"/>
                          </Border>

                          <TextBlock Grid.Column="1"
                                     Text="{Binding TimeText}"
                                     HorizontalAlignment="Right"
                                     FontSize="12"
                                     Foreground="#8A8178"/>
                        </Grid>

                        <TextBlock Text="{Binding Title}"
                                   FontWeight="Bold"
                                   TextWrapping="Wrap"
                                   Foreground="#37332F"/>

                        <TextBlock Text="{Binding Text}"
                                   TextWrapping="Wrap"
                                   FontFamily="Consolas"
                                   FontSize="13"
                                   LineHeight="18"
                                   Foreground="#34302C"/>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </Grid>
        </Border>

        <Expander Grid.Row="1"
                  Grid.ColumnSpan="3"
                  Header="Raw events"
                  IsExpanded="{Binding ShowRawEvents}">
          <Border CornerRadius="16"
                  Padding="10"
                  Background="#FFFDF8"
                  BorderBrush="#E7DCCB"
                  BorderThickness="1"
                  MaxHeight="220">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          Classes="accentScrollArea">
              <ItemsControl ItemsSource="{Binding RawEvents}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="models:DisplayEvent">
                    <TextBlock Text="{Binding RawJson}"
                               FontFamily="Consolas"
                               FontSize="12"
                               TextWrapping="NoWrap"
                               Margin="0,0,0,6"
                               Foreground="#4A4640"/>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </Border>
        </Expander>
      </Grid>
    </Grid>

    <Border Grid.Row="2"
            Grid.ColumnSpan="2"
            CornerRadius="16"
            Padding="10"
            Background="#FFFDF8"
            BorderBrush="#E7DCCB"
            BorderThickness="1">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Text="{Binding StatusMessage}"
                   Foreground="#3A3732"/>
        <ProgressBar Grid.Column="1"
                     Classes="accentProgress"
                     IsIndeterminate="{Binding IsBusy}"
                     Width="160"
                     Height="8"
                     VerticalAlignment="Center"/>
      </Grid>
    </Border>
  </Grid>
</suki:SukiWindow>
