<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:CXTracer.ViewModels"
             xmlns:models="clr-namespace:CXTracer.Models"
             xmlns:behaviors="clr-namespace:CXTracer.Behaviors"
             xmlns:converters="clr-namespace:CXTracer.Converters"
             x:Class="CXTracer.Views.DetailPopupOverlay"
             x:DataType="vm:MainWindowViewModel"
             mc:Ignorable="d">
  <UserControl.Resources>
    <converters:ImagePathToBitmapConverter x:Key="ImagePathToBitmapConverter" />
  </UserControl.Resources>

  <Panel IsVisible="{Binding IsDetailPopupOpen}"
         Background="Transparent">
    <!-- Backdrop -->
    <Border Background="#80000000"
            PointerPressed="DetailBackdrop_PointerPressed"/>

    <!-- Content panel -->
    <Border HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Width="800"
            MaxHeight="680"
            CornerRadius="20"
            Padding="24"
            Background="{Binding DetailPopupEvent.CardBackground}"
            BorderBrush="{Binding DetailPopupEvent.CardBorder}"
            BorderThickness="2"
            BoxShadow="0 8 32 0 #40000000"
            PointerPressed="DetailPanel_PointerPressed">
      <Grid RowDefinitions="Auto,*">
        <!-- Header -->
        <Grid ColumnDefinitions="Auto,*,Auto">
          <Border CornerRadius="999"
                  Padding="10,4"
                  Background="{Binding DetailPopupEvent.RoleBadgeBackground}">
            <TextBlock Text="{Binding DetailPopupEvent.RoleLabel}"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="{Binding DetailPopupEvent.RoleBadgeForeground}"/>
          </Border>

          <TextBlock Grid.Column="1"
                     Text="{Binding DetailPopupEvent.TimeText}"
                     HorizontalAlignment="Right"
                     VerticalAlignment="Center"
                     FontSize="13"
                     Foreground="#8A8178"
                     Margin="0,0,8,0"/>

          <Button Grid.Column="2"
                  Classes="roundIconButton"
                  Click="DetailClose_Click"
                  ToolTip.Tip="{DynamicResource Close}">
            <Border Width="28" Height="28" CornerRadius="14" Background="#1A000000">
              <TextBlock Text="✕"
                         FontSize="14"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         Foreground="#6A6460"/>
            </Border>
          </Button>
        </Grid>

        <!-- Scrollable body -->
        <ScrollViewer Grid.Row="1"
                      Margin="0,14,0,0"
                      HorizontalScrollBarVisibility="Disabled">
          <StackPanel Spacing="12">
            <TextBlock behaviors:SearchHighlight.Text="{Binding DetailPopupEvent.Title}"
                       behaviors:SearchHighlight.Query="{Binding EventSearchText}"
                       FontWeight="Bold"
                       FontSize="16"
                       TextWrapping="Wrap"
                       Foreground="#37332F"
                       IsVisible="{Binding DetailPopupEvent.Title, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

            <TextBlock behaviors:SearchHighlight.Text="{Binding DetailPopupEvent.Text}"
                       behaviors:SearchHighlight.Query="{Binding EventSearchText}"
                       TextWrapping="Wrap"
                       FontSize="15"
                       LineHeight="22"
                       Foreground="#34302C"
                       IsVisible="{Binding !DetailPopupEvent.IsDiff}"/>

            <ItemsControl ItemsSource="{Binding DetailPopupEvent.DiffLines}"
                          IsVisible="{Binding DetailPopupEvent.IsDiff}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="models:DiffLine">
                  <Border Background="{Binding Background}"
                          Padding="6,2"
                          Margin="0,1"
                          CornerRadius="4">
                    <TextBlock behaviors:SearchHighlight.Text="{Binding Text}"
                               behaviors:SearchHighlight.Query="{Binding $parent[UserControl].DataContext.EventSearchText}"
                               FontFamily="Consolas"
                               FontSize="13.5"
                               Foreground="{Binding Foreground}"
                               TextWrapping="Wrap"/>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Button Command="{Binding ShowImageViewerCommand}"
                    CommandParameter="{Binding DetailPopupEvent.ImagePath}"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0"
                    Cursor="Hand"
                    IsVisible="{Binding DetailPopupEvent.HasImage}">
              <Button.Styles>
                <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                  <Setter Property="Background" Value="Transparent" />
                </Style>
                <Style Selector="Button:pressed /template/ ContentPresenter#PART_ContentPresenter">
                  <Setter Property="Background" Value="Transparent" />
                </Style>
              </Button.Styles>
              <Border CornerRadius="8"
                      ClipToBounds="True"
                      MaxHeight="400"
                      Margin="0,4,0,0">
                <Image Source="{Binding DetailPopupEvent.ImagePath, Converter={StaticResource ImagePathToBitmapConverter}}"
                       Stretch="Uniform" />
              </Border>
            </Button>

            <Expander Header="{DynamicResource RawJson}"
                      Padding="0"
                      Margin="0,4,0,0">
              <Border CornerRadius="10"
                      Padding="10"
                      Background="#F7F5EF"
                      BorderBrush="#E7DCCB"
                      BorderThickness="1"
                      MaxHeight="260">
                <ScrollViewer HorizontalScrollBarVisibility="Auto">
                  <TextBlock Text="{Binding DetailPopupEvent.FormattedRawJson}"
                             FontFamily="Consolas"
                             FontSize="12"
                             TextWrapping="NoWrap"
                             Foreground="#4A4640"/>
                </ScrollViewer>
              </Border>
            </Expander>
          </StackPanel>
        </ScrollViewer>
      </Grid>
    </Border>
  </Panel>
</UserControl>
