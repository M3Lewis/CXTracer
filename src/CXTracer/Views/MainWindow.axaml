

<suki:SukiWindow xmlns="https://github.com/avaloniaui"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:suki="clr-namespace:SukiUI.Controls;assembly=SukiUI"
                 xmlns:vm="clr-namespace:CXTracer.ViewModels"
                 xmlns:models="clr-namespace:CXTracer.Models"
                 x:Class="CXTracer.Views.MainWindow"
                 x:DataType="vm:MainWindowViewModel"
                 mc:Ignorable="d"
                 Width="1380"
                 Height="860"
                 MinWidth="1080"
                 MinHeight="640"
                 Title="CXTracer"
                 Icon="{StaticResource AppIcon}"
                 Background="#FBF7EF"
                 KeyDown="Window_KeyDown"
                 BackgroundStyle="Flat">
  <suki:SukiWindow.Hosts>
    <suki:SukiToastHost Manager="{Binding ToastManager}" />
  </suki:SukiWindow.Hosts>
  <suki:SukiWindow.Styles>
    <Style Selector="Button.roundIconButton">
      <Setter Property="Width" Value="34" />
      <Setter Property="Height" Value="34" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="ListBox.sessionList ListBoxItem:selected /template/ Path">
      <Setter Property="Fill" Value="#E97924" />
    </Style>
    <Style Selector="ListBox.sessionList ListBoxItem:selected /template/ PathIcon">
      <Setter Property="Foreground" Value="#E97924" />
    </Style>
    <Style Selector="ListBox.sessionList ListBoxItem">
      <Setter Property="Focusable" Value="False" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0" />
      <Setter Property="Template">
        <ControlTemplate>
          <Border Background="Transparent"
                  BorderThickness="0"
                  Padding="0"
                  Margin="0">
            <ContentPresenter Name="PART_ContentPresenter"
                              Content="{TemplateBinding Content}"
                              ContentTemplate="{TemplateBinding ContentTemplate}"
                              HorizontalContentAlignment="Stretch"
                              VerticalContentAlignment="Stretch"
                              Background="Transparent"
                              BorderThickness="0"
                              Padding="{TemplateBinding Padding}" />
          </Border>
        </ControlTemplate>
      </Setter>
    </Style>
    <Style Selector="ListBox.sessionList Border.sessionCard">
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="BorderBrush" Value="#E7DCCB" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="ListBox.sessionList ListBoxItem:selected Border.sessionCard">
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="BorderBrush" Value="#E97924" />
      <Setter Property="BorderThickness" Value="2" />
    </Style>
    <Style Selector="ScrollViewer.accentScrollArea ScrollBar /template/ Thumb">
      <Setter Property="Background" Value="#E97924" />
    </Style>
    <Style Selector="ScrollViewer.accentScrollArea ScrollBar:pointerover /template/ Thumb">
      <Setter Property="Background" Value="#D76618" />
    </Style>
    <Style Selector="ProgressBar.accentProgress">
      <Setter Property="Foreground" Value="#E97924" />
      <Setter Property="Background" Value="#F3DFCF" />
    </Style>
    <Style Selector="ProgressBar.accentProgress /template/ Rectangle">
      <Setter Property="Fill" Value="#E97924" />
    </Style>
    <Style Selector="Border.transcriptPane">
      <Setter Property="BorderBrush" Value="#E7DCCB" />
      <Setter Property="BorderThickness" Value="2" />
    </Style>
    <Style Selector="Border.transcriptPane.active">
      <Setter Property="BorderBrush" Value="#E97924" />
    </Style>
    <!-- Transcript ListBox: no selection chrome, no keyboard nav capture -->
    <Style Selector="ListBox.transcriptList">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Focusable" Value="False" />
      <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
    </Style>
    <Style Selector="ListBox.transcriptList ListBoxItem">
      <Setter Property="Focusable" Value="False" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0" />
      <Setter Property="MinHeight" Value="0" />
      <Setter Property="Template">
        <ControlTemplate>
          <ContentPresenter Name="PART_ContentPresenter"
                            Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="{TemplateBinding Padding}" />
        </ControlTemplate>
      </Setter>
    </Style>
    <!-- Accent scrollbar for transcript ListBoxes -->
    <Style Selector="ListBox.transcriptList ScrollBar /template/ Thumb">
      <Setter Property="Background" Value="#E97924" />
    </Style>
    <Style Selector="ListBox.transcriptList ScrollBar:pointerover /template/ Thumb">
      <Setter Property="Background" Value="#D76618" />
    </Style>
  </suki:SukiWindow.Styles>

  <Panel>
  <Grid RowDefinitions="Auto,*,Auto"
        ColumnDefinitions="340,*"
        Margin="14"
        ColumnSpacing="12"
        RowSpacing="12"
        Background="#FBF7EF">

    <Border Grid.Row="0"
            Grid.ColumnSpan="2"
            CornerRadius="18"
            Padding="12"
            Background="#FFFDF8"
            BorderBrush="#E7DCCB"
            BorderThickness="1">
      <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" ColumnSpacing="10" VerticalAlignment="Center">
        <TextBlock Text="{DynamicResource SessionsRoot}"
                   FontWeight="SemiBold"
                   VerticalAlignment="Center"
                   Foreground="#3E3A36"/>

        <TextBox Grid.Column="1"
                 Text="{Binding RootPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 PlaceholderText="C:\Users\you\.codex\sessions 或 WSL UNC 路径"
                 FontFamily="Consolas"/>

        <Button Grid.Column="2" Classes="toolbarButton" Content="{DynamicResource Default}" Command="{Binding OpenDefaultRootCommand}"/>
        <Button Grid.Column="3" Classes="toolbarButton" Content="{DynamicResource Refresh}" Command="{Binding RefreshCommand}"/>
        <CheckBox Grid.Column="4"
                  Classes="preferenceCheckBox"
                  Content="{DynamicResource PinSelected}"
                  IsThreeState="False"
                  IsChecked="{Binding PinSelectedSession, Mode=TwoWay}"
                  VerticalAlignment="Center"/>
      </Grid>
    </Border>

    <Border Grid.Row="1"
            Grid.Column="0"
            CornerRadius="18"
            Padding="10"
            Background="#FFFDF8"
            BorderBrush="#E7DCCB"
            BorderThickness="1">
      <Grid RowDefinitions="Auto,Auto,*" RowSpacing="10">
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel>
            <TextBlock Text="{DynamicResource CodexSessions}"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="#3A3732"/>
            <TextBlock Text="{Binding SessionCountText}"
                       Foreground="#746A5F"/>
          </StackPanel>

          <Border Grid.Column="1"
                  CornerRadius="8"
                  Padding="6,1"
                  VerticalAlignment="Top"
                  Background="#FFFFFF"
                  BorderBrush="#E7DCCB"
                  BorderThickness="1">
            <TextBlock Text="{DynamicResource ReadOnly}"
                       FontSize="12"
                       Foreground="#6C7A6F"/>
          </Border>
        </Grid>

        <TextBox Grid.Row="1"
                 Text="{Binding SessionSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 PlaceholderText="{DynamicResource SearchSessionsPlaceholder}"/>

        <ListBox Grid.Row="2"
                 Classes="sessionList"
                 Focusable="False"
                 ItemsSource="{Binding Sessions}"
                 SelectedItem="{Binding SelectedSession, Mode=TwoWay}">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="models:SessionInfo">
              <Border Classes="sessionCard"
                      CornerRadius="10"
                      Padding="8"
                      Margin="0,2">
                <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="4">
                  <TextBlock Text="{Binding DisplayTitle}"
                             FontWeight="SemiBold"
                             TextWrapping="Wrap"
                             MaxLines="2"
                             Foreground="#3D3445"/>

                  <Border Grid.Column="1"
                          CornerRadius="8"
                          Padding="6,1"
                          VerticalAlignment="Top"
                          Background="#F8F8F8"
                          BorderBrush="#E7DCCB"
                          BorderThickness="1">
                    <TextBlock Text="{Binding StatusText}"
                               FontSize="11"
                               Foreground="#7A6F63"/>
                  </Border>

                  <TextBlock Grid.Row="1"
                             Grid.ColumnSpan="2"
                             Text="{Binding DisplaySubtitle}"
                             Foreground="#746A5F"
                             FontSize="12"/>

                  <TextBlock Grid.Row="2"
                             Grid.ColumnSpan="2"
                             Text="{Binding FilePath}"
                             Foreground="#9A9187"
                             FontSize="11"
                             TextTrimming="CharacterEllipsis"/>
                </Grid>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Grid>
    </Border>

    <Grid Grid.Row="1" Grid.Column="1" RowDefinitions="Auto,*" RowSpacing="10">
      <Border CornerRadius="18"
              Padding="10"
              Background="#FFFDF8"
              BorderBrush="#E7DCCB"
              BorderThickness="1">
        <Grid ColumnDefinitions="*,Auto,Auto,160,Auto,Auto" ColumnSpacing="10">
          <StackPanel Grid.Column="0">
            <TextBlock Text="{Binding SelectedSessionPath}"
                       FontFamily="Consolas"
                       TextTrimming="CharacterEllipsis"
                       Foreground="#3A3732"
                       ToolTip.Tip="{Binding SelectedSessionPath}"
                       PointerPressed="SessionPath_PointerPressed"/>
            <TextBlock Text="{Binding EventCountText}"
                       Foreground="#746A5F"
                       FontSize="12"/>
          </StackPanel>

          <ToggleButton Grid.Column="1"
                        Classes="toolbarButton"
                        Content="{DynamicResource Raw}"
                        VerticalAlignment="Center"
                        IsChecked="{Binding ShowRawEvents}"/>

          <Button Grid.Column="2"
                  Classes="toolbarButton"
                  Content="{DynamicResource Settings}"
                  VerticalAlignment="Center"
                  Click="Settings_Click"/>

          <TextBox Grid.Column="3"
                   Text="{Binding EventSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                   PlaceholderText="{DynamicResource FilterPlaceholder}"
                   VerticalAlignment="Center"/>

          <ComboBox Grid.Column="4"
                    ItemsSource="{Binding FilterOptions}"
                    SelectedItem="{Binding SelectedFilter}"
                    MinWidth="150"
                    VerticalAlignment="Center">
            <ComboBox.ItemTemplate>
              <DataTemplate x:DataType="vm:FilterOptionItem">
                <TextBlock Text="{Binding DisplayName}"/>
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>

          <Button Grid.Column="5"
                  Classes="toolbarButton"
                  Content="{DynamicResource ClearSearch}"
                  VerticalAlignment="Center"
                  Command="{Binding ClearSearchCommand}"/>
        </Grid>
      </Border>

      <Grid Grid.Row="1"
            ColumnDefinitions="*,8,*"
            RowDefinitions="*,Auto"
            ColumnSpacing="0"
            RowSpacing="10">

        <Border Grid.Column="0"
                Classes="transcriptPane"
                Classes.active="{Binding IsConversationPaneActive}"
                CornerRadius="18"
                Padding="10"
                Background="#FFFDF8">
          <Grid RowDefinitions="Auto,*" RowSpacing="8">
            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
              <TextBlock Text="{DynamicResource Conversation}"
                         FontSize="18"
                         FontWeight="Bold"
                         Foreground="#3A3732"
                         VerticalAlignment="Center"/>

              <Button Grid.Column="1"
                      Classes="roundIconButton"
                      Click="ConversationUp_Click"
                      ToolTip.Tip="{DynamicResource PrevMessage}">
                <Border Width="30"
                        Height="30"
                        CornerRadius="15"
                        Background="#FFFFFF"
                        BorderBrush="#E7DCCB"
                        BorderThickness="1">
                  <Path Width="12"
                        Height="12"
                        Stretch="Uniform"
                        Fill="#6F655C"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Data="{StaticResource IconChevronUp}" />
                </Border>
              </Button>

              <Button Grid.Column="2"
                      Classes="roundIconButton"
                      Click="ConversationDown_Click"
                      ToolTip.Tip="{DynamicResource NextMessage}">
                <Border Width="30"
                        Height="30"
                        CornerRadius="15"
                        Background="#FFFFFF"
                        BorderBrush="#E7DCCB"
                        BorderThickness="1">
                  <Path Width="12"
                        Height="12"
                        Stretch="Uniform"
                        Fill="#6F655C"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Data="{StaticResource IconChevronDown}" />
                </Border>
              </Button>
            </Grid>

            <ListBox x:Name="ConversationListBox"
                     Grid.Row="1"
                     Classes="transcriptList"
                     ItemsSource="{Binding ConversationEvents}"
                     SelectionMode="Toggle">
              <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel />
                </ItemsPanelTemplate>
              </ListBox.ItemsPanel>
              <ListBox.ItemTemplate>
                <DataTemplate x:DataType="models:DisplayEvent">
                  <Border CornerRadius="16"
                          Padding="12"
                          Margin="0,0,0,10"
                          Background="{Binding CardBackground}"
                          BorderBrush="{Binding CardBorder}"
                          BorderThickness="{Binding CardBorderThickness}"
                          PointerPressed="CardBorder_PointerPressed">
                    <StackPanel Spacing="7">
                      <Grid ColumnDefinitions="Auto,*">
                        <Border CornerRadius="999"
                                Padding="8,3"
                                Background="{Binding RoleBadgeBackground}">
                          <TextBlock Text="{Binding RoleLabel}"
                                     FontSize="12"
                                     FontWeight="SemiBold"
                                     Foreground="{Binding RoleBadgeForeground}"/>
                        </Border>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Spacing="5"
                                    VerticalAlignment="Center">
                          <Border Background="#F3EBE0"
                                  BorderBrush="#DDD5C8"
                                  BorderThickness="1"
                                  CornerRadius="999"
                                  Padding="5,1"
                                  MinWidth="22"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  IsVisible="{Binding ColumnSequenceText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                            <TextBlock Text="{Binding ColumnSequenceText}"
                                       FontSize="11"
                                       Foreground="#8A8178"
                                       FontWeight="Medium"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                          </Border>
                          <Border Background="#EDE5DA"
                                  BorderBrush="#DDD5C8"
                                  BorderThickness="1"
                                  CornerRadius="999"
                                  Padding="5,1"
                                  MinWidth="22"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  IsVisible="{Binding MergedSequenceText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                            <TextBlock Text="{Binding MergedSequenceText}"
                                       FontSize="11"
                                       Foreground="#8A8178"
                                       FontWeight="Medium"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                          </Border>
                          <TextBlock Text="{Binding TimeText}"
                                     FontSize="12"
                                     Foreground="#8A8178"
                                     VerticalAlignment="Center"/>
                        </StackPanel>
                      </Grid>

                      <TextBlock Text="{Binding Title}"
                                 FontWeight="Bold"
                                 Foreground="#37332F"/>

                      <TextBlock Text="{Binding Text}"
                                 TextWrapping="Wrap"
                                 FontSize="14"
                                 LineHeight="20"
                                 Foreground="#34302C"/>
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </Grid>
        </Border>

        <GridSplitter Grid.Column="1"
                      Width="8"
                      Background="#F0E8DC"
                      HorizontalAlignment="Stretch"/>

        <Border Grid.Column="2"
                Classes="transcriptPane"
                Classes.active="{Binding IsExecutionPaneActive}"
                CornerRadius="18"
                Padding="10"
                Background="#FFFDF8">
          <Grid RowDefinitions="Auto,*" RowSpacing="8">
            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
              <TextBlock Text="{DynamicResource Execution}"
                         FontSize="18"
                         FontWeight="Bold"
                         Foreground="#3A3732"
                         VerticalAlignment="Center"/>

              <Button Grid.Column="1"
                      Width="34"
                      Height="34"
                      Padding="0"
                      Background="Transparent"
                      BorderThickness="0"
                      Click="ExecutionUp_Click"
                      ToolTip.Tip="{DynamicResource PrevMessage}">
                <Border Width="30"
                        Height="30"
                        CornerRadius="15"
                        Background="#FFFFFF"
                        BorderBrush="#E7DCCB"
                        BorderThickness="1">
                  <Path Width="12"
                        Height="12"
                        Stretch="Uniform"
                        Fill="#6F655C"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Data="M 12 6 L 20 17 L 4 17 Z"/>
                </Border>
              </Button>

              <Button Grid.Column="2"
                      Width="34"
                      Height="34"
                      Padding="0"
                      Background="Transparent"
                      BorderThickness="0"
                      Click="ExecutionDown_Click"
                      ToolTip.Tip="{DynamicResource NextMessage}">
                <Border Width="30"
                        Height="30"
                        CornerRadius="15"
                        Background="#FFFFFF"
                        BorderBrush="#E7DCCB"
                        BorderThickness="1">
                  <Path Width="12"
                        Height="12"
                        Stretch="Uniform"
                        Fill="#6F655C"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Data="M 4 7 L 20 7 L 12 18 Z"/>
                </Border>
              </Button>
            </Grid>

            <ListBox x:Name="ExecutionListBox"
                     Grid.Row="1"
                     Classes="transcriptList"
                     ItemsSource="{Binding ExecutionEvents}"
                     SelectionMode="Toggle">
              <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel />
                </ItemsPanelTemplate>
              </ListBox.ItemsPanel>
              <ListBox.ItemTemplate>
                <DataTemplate x:DataType="models:DisplayEvent">
                  <Border CornerRadius="16"
                          Padding="12"
                          Margin="0,0,0,10"
                          Background="{Binding CardBackground}"
                          BorderBrush="{Binding CardBorder}"
                          BorderThickness="{Binding CardBorderThickness}"
                          PointerPressed="CardBorder_PointerPressed">
                    <StackPanel Spacing="7">
                      <Grid ColumnDefinitions="Auto,*">
                        <Border CornerRadius="999"
                                Padding="8,3"
                                Background="{Binding RoleBadgeBackground}">
                          <TextBlock Text="{Binding RoleLabel}"
                                     FontSize="12"
                                     FontWeight="SemiBold"
                                     Foreground="{Binding RoleBadgeForeground}"/>
                        </Border>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Spacing="5"
                                    VerticalAlignment="Center">
                          <Border Background="#F3EBE0"
                                  BorderBrush="#DDD5C8"
                                  BorderThickness="1"
                                  CornerRadius="999"
                                  Padding="5,1"
                                  MinWidth="22"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  IsVisible="{Binding ColumnSequenceText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                            <TextBlock Text="{Binding ColumnSequenceText}"
                                       FontSize="11"
                                       Foreground="#8A8178"
                                       FontWeight="Medium"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                          </Border>
                          <Border Background="#EDE5DA"
                                  BorderBrush="#DDD5C8"
                                  BorderThickness="1"
                                  CornerRadius="999"
                                  Padding="5,1"
                                  MinWidth="22"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  IsVisible="{Binding MergedSequenceText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                            <TextBlock Text="{Binding MergedSequenceText}"
                                       FontSize="11"
                                       Foreground="#8A8178"
                                       FontWeight="Medium"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                          </Border>
                          <TextBlock Text="{Binding TimeText}"
                                     FontSize="12"
                                     Foreground="#8A8178"
                                     VerticalAlignment="Center"/>
                        </StackPanel>
                      </Grid>

                      <TextBlock Text="{Binding Title}"
                                 FontWeight="Bold"
                                 TextWrapping="Wrap"
                                 Foreground="#37332F"/>

                      <TextBlock Text="{Binding Text}"
                                 TextWrapping="Wrap"
                                 FontFamily="Consolas"
                                 FontSize="13"
                                 LineHeight="18"
                                 Foreground="#34302C"/>
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </Grid>
        </Border>

        <Expander Grid.Row="1"
                  Grid.ColumnSpan="3"
                  Header="{DynamicResource RawEvents}"
                  IsExpanded="{Binding ShowRawEvents}">
          <Border CornerRadius="16"
                  Padding="10"
                  Background="#FFFDF8"
                  BorderBrush="#E7DCCB"
                  BorderThickness="1"
                  MaxHeight="220">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          Classes="accentScrollArea">
              <ItemsControl ItemsSource="{Binding RawEvents}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="models:DisplayEvent">
                    <Border CornerRadius="8"
                            Padding="10"
                            Margin="0,0,0,8"
                            Background="{Binding CardBackground}"
                            BorderBrush="{Binding CardBorder}"
                            BorderThickness="{Binding CardBorderThickness}"
                            PointerPressed="CardBorder_PointerPressed">
                      <StackPanel Spacing="5">
                        <Grid ColumnDefinitions="Auto,*">
                          <Border CornerRadius="999"
                                  Padding="6,2"
                                  Background="{Binding RoleBadgeBackground}">
                            <TextBlock Text="{Binding RoleLabel}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{Binding RoleBadgeForeground}"/>
                          </Border>

                          <TextBlock Grid.Column="1"
                                     Text="{Binding TimeText}"
                                     HorizontalAlignment="Right"
                                     FontSize="11"
                                     Foreground="#8A8178"/>
                        </Grid>

                        <TextBlock Text="{Binding FormattedRawJson}"
                                   FontFamily="Consolas"
                                   FontSize="12"
                                   TextWrapping="NoWrap"
                                   Foreground="#4A4640"/>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </Border>
        </Expander>
      </Grid>
    </Grid>

    <Border Grid.Row="2"
            Grid.ColumnSpan="2"
            CornerRadius="16"
            Padding="10"
            Background="#FFFDF8"
            BorderBrush="#E7DCCB"
            BorderThickness="1">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Text="{Binding StatusMessage}"
                   Foreground="#3A3732"/>
        <ProgressBar Grid.Column="1"
                     Classes="accentProgress"
                     IsIndeterminate="{Binding IsBusy}"
                     Width="160"
                     Height="8"
                     VerticalAlignment="Center"/>
      </Grid>
    </Border>
  </Grid>

  <!-- Detail popup overlay -->
  <Panel IsVisible="{Binding IsDetailPopupOpen}"
         Background="Transparent">
    <!-- Backdrop -->
    <Border Background="#80000000"
            PointerPressed="DetailBackdrop_PointerPressed"/>

    <!-- Content panel -->
    <Border HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Width="800"
            MaxHeight="680"
            CornerRadius="20"
            Padding="24"
            Background="{Binding DetailPopupEvent.CardBackground}"
            BorderBrush="{Binding DetailPopupEvent.CardBorder}"
            BorderThickness="2"
            BoxShadow="0 8 32 0 #40000000"
            PointerPressed="DetailPanel_PointerPressed">
      <Grid RowDefinitions="Auto,*">
        <!-- Header -->
        <Grid ColumnDefinitions="Auto,*,Auto">
          <Border CornerRadius="999"
                  Padding="10,4"
                  Background="{Binding DetailPopupEvent.RoleBadgeBackground}">
            <TextBlock Text="{Binding DetailPopupEvent.RoleLabel}"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="{Binding DetailPopupEvent.RoleBadgeForeground}"/>
          </Border>

          <TextBlock Grid.Column="1"
                     Text="{Binding DetailPopupEvent.TimeText}"
                     HorizontalAlignment="Right"
                     VerticalAlignment="Center"
                     FontSize="13"
                     Foreground="#8A8178"
                     Margin="0,0,8,0"/>

          <Button Grid.Column="2"
                  Classes="roundIconButton"
                  Click="DetailClose_Click"
                  ToolTip.Tip="{DynamicResource Close}">
            <Border Width="28" Height="28" CornerRadius="14" Background="#1A000000">
              <TextBlock Text="✕"
                         FontSize="14"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         Foreground="#6A6460"/>
            </Border>
          </Button>
        </Grid>

        <!-- Scrollable body -->
        <ScrollViewer Grid.Row="1"
                      Margin="0,14,0,0"
                      HorizontalScrollBarVisibility="Disabled">
          <StackPanel Spacing="12">
            <TextBlock Text="{Binding DetailPopupEvent.Title}"
                       FontWeight="Bold"
                       FontSize="16"
                       TextWrapping="Wrap"
                       Foreground="#37332F"
                       IsVisible="{Binding DetailPopupEvent.Title, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

            <TextBlock Text="{Binding DetailPopupEvent.Text}"
                       TextWrapping="Wrap"
                       FontSize="15"
                       LineHeight="22"
                       Foreground="#34302C"/>

            <Expander Header="{DynamicResource RawJson}"
                      Padding="0"
                      Margin="0,4,0,0">
              <Border CornerRadius="10"
                      Padding="10"
                      Background="#F7F5EF"
                      BorderBrush="#E7DCCB"
                      BorderThickness="1"
                      MaxHeight="260">
                <ScrollViewer HorizontalScrollBarVisibility="Auto">
                  <TextBlock Text="{Binding DetailPopupEvent.FormattedRawJson}"
                             FontFamily="Consolas"
                             FontSize="12"
                             TextWrapping="NoWrap"
                             Foreground="#4A4640"/>
                </ScrollViewer>
              </Border>
            </Expander>
          </StackPanel>
        </ScrollViewer>
      </Grid>
    </Border>
  </Panel>
  </Panel>

</suki:SukiWindow>
