<suki:SukiWindow xmlns="https://github.com/avaloniaui"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:suki="clr-namespace:SukiUI.Controls;assembly=SukiUI"
                 xmlns:vm="clr-namespace:CXTracer.ViewModels"
                 x:Class="CXTracer.Views.SettingsWindow"
                 x:DataType="vm:SettingsWindowViewModel"
                 mc:Ignorable="d"
                 Width="460"
                 SizeToContent="Height"
                 MinWidth="420"
                 MinHeight="240"
                 Title="{DynamicResource Settings}"
                 Icon="{StaticResource AppIcon}"
                 Background="#FBF7EF"
                 KeyDown="Window_KeyDown"
                 BackgroundStyle="Flat">
  <Border Margin="14"
          CornerRadius="18"
          Padding="16"
          Background="#FFFDF8"
          BorderBrush="#E7DCCB"
          BorderThickness="1">
    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="14">
      <TextBlock Text="{DynamicResource Navigation}"
                 FontSize="18"
                 FontWeight="Bold"
                 Foreground="#3A3732"/>

      <CheckBox Grid.Row="1"
                Classes="preferenceCheckBox"
                Content="{DynamicResource SynchronizedNavigation}"
                IsThreeState="False"
                IsChecked="{Binding IsSynchronizedNavigationEnabled, Mode=TwoWay}"
                VerticalAlignment="Center"/>

      <CheckBox Grid.Row="2"
                Classes="preferenceCheckBox"
                Content="{DynamicResource ExpandAllEvents}"
                IsThreeState="False"
                IsChecked="{Binding ExpandAllEventsByDefault, Mode=TwoWay}"
                VerticalAlignment="Center"/>

      <Grid Grid.Row="3"
            ColumnDefinitions="Auto,*,Auto"
            ColumnSpacing="10"
            VerticalAlignment="Top">
        <TextBlock Text="{DynamicResource Shortcut}"
                   VerticalAlignment="Center"
                   Foreground="#3A3732"/>

        <Button Grid.Column="1"
                Classes="toolbarButton"
                Content="{Binding ShortcutEditorText}"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                Command="{Binding StartSyncShortcutCaptureCommand}"/>

        <Button Grid.Column="2"
                Classes="toolbarButton"
                Content="{DynamicResource OK}"
                MinWidth="64"
                Command="{Binding ConfirmSyncShortcutCommand}"/>
      </Grid>

      <!-- Divider -->
      <Border Grid.Row="4"
              Height="1"
              Background="#E7DCCB"
              HorizontalAlignment="Stretch"/>

      <!-- System Tray Section -->
      <TextBlock Grid.Row="5"
                 Text="{DynamicResource SystemTray}"
                 FontSize="18"
                 FontWeight="Bold"
                 Foreground="#3A3732"/>

      <CheckBox Grid.Row="6"
                Classes="preferenceCheckBox"
                Content="{DynamicResource MinimizeToTray}"
                IsThreeState="False"
                IsChecked="{Binding MinimizeToTray, Mode=TwoWay}"
                VerticalAlignment="Center"/>

      <CheckBox Grid.Row="7"
                Classes="preferenceCheckBox"
                Content="{DynamicResource CloseToTray}"
                IsThreeState="False"
                IsChecked="{Binding CloseToTray, Mode=TwoWay}"
                VerticalAlignment="Center"/>

      <!-- Divider -->
      <Border Grid.Row="8"
              Height="1"
              Background="#E7DCCB"
              HorizontalAlignment="Stretch"/>

      <!-- Language Section -->
      <Grid Grid.Row="9"
            ColumnDefinitions="Auto,*"
            ColumnSpacing="10"
            VerticalAlignment="Center">
        <TextBlock Text="{DynamicResource Language}"
                   FontWeight="SemiBold"
                   VerticalAlignment="Center"
                   Foreground="#3A3732"/>

        <ComboBox Grid.Column="1"
                  ItemsSource="{x:Static vm:SettingsWindowViewModel.LanguageDisplayNames}"
                  SelectedIndex="{Binding SelectedLanguageIndex, Mode=TwoWay}"
                  MinWidth="140"
                  HorizontalAlignment="Right"/>
      </Grid>

      <!-- Divider -->
      <Border Grid.Row="10"
              Height="1"
              Background="#E7DCCB"
              HorizontalAlignment="Stretch"/>

      <!-- About Section -->
      <Grid Grid.Row="11"
            ColumnDefinitions="*,Auto"
            ColumnSpacing="10"
            VerticalAlignment="Center">
        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
          <TextBlock Text="{DynamicResource Author}"
                     FontWeight="SemiBold"
                     Foreground="#3A3732"/>
          <TextBlock Text=":"
          FontWeight="SemiBold"
                     Foreground="#746A5F"/>
          <TextBlock Text="M3Lewis"
                FontWeight="SemiBold"
                     Foreground="#746A5F"/>
        </StackPanel>

        <Button Grid.Column="1"
                Classes="toolbarButton"
                Command="{Binding OpenGithubCommand}"
                ToolTip.Tip="GitHub: M3Lewis"
                Padding="6"
                Width="32"
                Height="32"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center">
          <PathIcon Data="{StaticResource IconGithub}"
                    Width="16"
                    Height="16"
                    Foreground="#3A3732"/>
        </Button>
      </Grid>

      <Grid Grid.Row="12"
            ColumnDefinitions="*,Auto"
            ColumnSpacing="12">
        <TextBlock Text="{Binding StatusMessage}"
                   Foreground="#746A5F"
                   TextWrapping="Wrap"
                   MaxLines="2"
                   TextTrimming="CharacterEllipsis"
                   VerticalAlignment="Center"/>

        <Button Grid.Column="1"
                Classes="toolbarButton"
                Content="{DynamicResource Close}"
                MinWidth="72"
                Click="Close_Click"/>
      </Grid>
    </Grid>
  </Border>
</suki:SukiWindow>
